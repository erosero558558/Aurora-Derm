---
import PublicMegaPanelV3 from './PublicMegaPanelV3.astro';

const { navModel } = Astro.props;
const currentPath = String(navModel.pathname || '/');
---

<header class="public-nav" data-public-nav>
    <div class="public-nav__bar">
        <a href={navModel.locale === 'en' ? '/en/' : '/es/'} class="public-nav__brand">
            <em class="public-nav__brand-eyebrow">{navModel.brand.eyebrow}</em>
            <span>{navModel.brand.line1}</span>
            <strong>{navModel.brand.line2}</strong>
        </a>
        <nav class="public-nav__links" aria-label={navModel.labels.primaryNav}>
            {
                navModel.links.map((link) => (
                    link.kind === 'mega' ? (
                        <details class="public-nav__mega-shell">
                            <summary class:list={['public-nav__link', currentPath.startsWith(link.href) && 'is-active']}>
                                {link.label}
                            </summary>
                            <PublicMegaPanelV3 mega={navModel.mega} locale={navModel.locale} labels={navModel.labels} />
                        </details>
                    ) : (
                        <a class:list={['public-nav__link', currentPath.startsWith(link.href) && 'is-active']} href={link.href}>
                            {link.label}
                        </a>
                    )
                ))
            }
        </nav>
        <div class="public-nav__actions">
            <a class="public-nav__lang sony-lang" href={navModel.switchHref}>{navModel.switchLabel}</a>
            <a href={navModel.bookingHref} class="public-nav__cta" data-analytics-event="open_public_cta" data-entry-surface="nav_primary_booking" data-cta-target="booking">
                {navModel.labels.book}
            </a>
        </div>
    </div>
</header>
