---
import { homePath, serviceHubPath, telemedicinePath } from '../lib/content.js';

const { locale = 'es', variant = 'service', service } = Astro.props;

const category = String(service?.category || 'clinical').toLowerCase();
const serviceName = service?.hero || service?.slug || (locale === 'en' ? 'service' : 'servicio');
const hubBase = serviceHubPath(locale);

const copy = {
    es: {
        hub: {
            eyebrow: 'Preparacion y aftercare',
            title: 'Cada familia del catalogo necesita una preparacion distinta y una salida clara.',
            description:
                'Este bloque evita una reserva ciega: muestra que conviene traer, como leer el post-consulta y cuando conviene cambiar de ruta.',
            cards: [
                {
                    step: 'Dermatologia clinica',
                    title: 'Llega con fotos, tiempo de evolucion y tratamientos activos',
                    body: 'En rutas clinicas la mejor decision sale de comparar brotes, sintomas, cambios y productos que ya se probaron.',
                    note: 'Aftercare: seguimiento de tolerancia, sintomas y necesidad de ampliar estudio si la respuesta no es coherente.',
                    cta: 'Abrir rutas clinicas',
                    href: `${hubBase}?category=clinical&intent=diagnosis`,
                    category: 'clinical',
                    intent: 'diagnosis',
                },
                {
                    step: 'Estetica medica',
                    title: 'Prepara baseline visual y evita medir el resultado demasiado pronto',
                    body: 'En estetica importa llegar con objetivo claro, zonas definidas y margen realista para edema, descamacion o cambios por fases.',
                    note: 'Aftercare: cuidar la piel, respetar ventanas de control y decidir repetir solo cuando la evolucion ya es interpretable.',
                    cta: 'Abrir rutas esteticas',
                    href: `${hubBase}?category=aesthetic&intent=rejuvenation`,
                    category: 'aesthetic',
