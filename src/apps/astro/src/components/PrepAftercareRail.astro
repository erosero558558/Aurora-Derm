                        body: 'Los primeros dias suelen ser para proteger la piel, evitar friccion innecesaria y dejar que la respuesta inicial se estabilice.',
                    },
                    {
                        step: 'Revision util',
                        title: 'Decide repetir o combinar solo cuando el resultado ya se puede leer',
                        body: 'El control correcto evita sobretratar: primero se interpreta evolucion real y luego se define si conviene repetir, esperar o combinar.',
                    },
                ],
            },
            children: {
                eyebrow: 'Preparacion y aftercare',
                title: `Como preparar ${serviceName} con una ruta familiar sostenible.`,
                description:
                    'En pediatria la ruta mejora cuando cuidadores entienden que observar, que aplicar en casa y cuando volver sin improvisar.',
                cards: [
                    {
                        step: 'Antes de la visita',
                        title: 'Trae fotos simples, rutina actual y cambios del sintoma',
                        body: 'Ayuda mucho saber que se uso ya, si el cuadro empeora por horarios o ambientes y que tan facil ha sido sostener el cuidado en casa.',
                    },
                    {
                        step: 'Aftercare en casa',
                        title: 'El plan debe ser corto, claro y cumplible para la familia',
                        body: 'La mejor salida no es la mas compleja, sino la que cuidadores pueden repetir sin friccion ni dudas nuevas cada dia.',
                    },
                    {
                        step: 'Volver antes',
                        title: 'Escala si hay dolor, mala tolerancia o cambio rapido',
                        body: 'Cuando el caso cambia de ritmo o aparecen alertas, la ruta correcta es revaluar pronto en lugar de insistir con el mismo esquema.',
                    },
                ],
            },
        },
    },
    en: {
        hub: {
            eyebrow: 'Preparation and aftercare',
            title: 'Each catalogue family needs a different setup and a clear aftercare logic.',
            description:
                'This block prevents blind booking. It shows what to bring, how to read the post-consult phase, and when a route should change.',
            cards: [
                {
                    step: 'Clinical dermatology',
                    title: 'Bring images, timeline, and active treatments',
                    body: 'Clinical routes work better when flares, symptoms, changes, and products already tried can be compared with context.',
                    note: 'Aftercare: monitor tolerance, symptoms, and whether the route needs broader testing if response stops making sense.',
                    cta: 'Open clinical routes',
                    href: `${hubBase}?category=clinical&intent=diagnosis`,
                    category: 'clinical',
                    intent: 'diagnosis',
                },
                {
                    step: 'Medical aesthetics',
                    title: 'Prepare a visual baseline and avoid judging results too early',
                    body: 'In aesthetics it helps to arrive with a clear goal, defined areas, and realistic room for swelling, peeling, or phased change.',
                    note: 'Aftercare: protect the skin, respect review windows, and repeat only once the evolution is interpretable.',
                    cta: 'Open aesthetic routes',
                    href: `${hubBase}?category=aesthetic&intent=rejuvenation`,
                    category: 'aesthetic',
                    intent: 'rejuvenation',
                },
                {
                    step: 'Pediatric dermatology',
                    title: 'Bring family context, realistic routine, and simple photos',
                    body: 'Pediatric cases improve when caregivers explain what is being used at home, what worsens the issue, and how symptoms evolve.',
                    note: 'Aftercare: watch simple alerts, keep a sustainable routine, and escalate early if pain or fast worsening appears.',
                    cta: 'Open pediatric routes',
                    href: `${hubBase}?category=children&intent=pediatric`,
                    category: 'children',
                    intent: 'pediatric',
                },
            ],
        },
        telemedicine: {
            eyebrow: 'Preparation and aftercare',
            title: 'How to prepare the remote consultation and what to do afterwards without losing continuity.',
            description:
                'Telemedicine works better when the prep material is useful, the follow-up logic is clear, and the signals for moving to in-person care stay visible.',
            cards: [
                {
                    step: 'Before you connect',
                    title: 'Prepare comparable images, daylight, and a brief history',
                    body: 'One close image, one contextual image, and a short timeline of change reduce back-and-forth and improve decision quality.',
                },
                {
                    step: 'Remote aftercare',
                    title: 'Keep the evidence and follow a simple review plan',
                    body: 'After the call, it helps to follow concrete guidance, monitor tolerance, and keep material ready for a short follow-up if needed.',
                },
                {
                    step: 'Move to in-person care',
                    title: 'Escalate if useful images are missing, urgency appears, or the case needs procedure',
                    body: 'Pain, suspicious lesions, poor image read, or lack of response justify moving the route to the clinic without resetting the funnel.',
                },
            ],
        },
        service: {
            clinical: {
                eyebrow: 'Preparation and aftercare',
                title: `How to prepare ${serviceName} and what to watch afterwards.`,
                description:
                    'The best treatment reading appears when preparation is concrete, aftercare is understood, and escalation alerts remain visible.',
                cards: [
                    {
                        step: 'Before the assessment',
                        title: 'Bring recent images, timeline, and active products',
                        body: 'It helps to arrive with comparable photos, real timing of evolution, and any cream, medication, or routine already being used.',
                    },
                    {
                        step: 'First days',
                        title: 'Read tolerance, symptoms, and early response calmly',
                        body: 'Useful aftercare does not chase instant perfection. It checks whether the plan is tolerated, whether the skin is responding, and whether quick adjustment is needed.',
                    },
                    {
                        step: 'When to escalate',
                        title: 'Do not keep pushing if alerts appear or the route stops making sense',
                        body: 'More pain, new lesions, worse inflammation, or no response are enough signals to expand testing, move to in-person care, or revise the plan.',
                    },
                ],
            },
            aesthetic: {
                eyebrow: 'Preparation and aftercare',
                title: `How to prepare ${serviceName} and protect the outcome.`,
                description:
                    'In aesthetics, results improve when the patient arrives with a clear goal, understands aftercare, and does not judge change outside the right window.',
                cards: [
                    {
                        step: 'Before the session',
                        title: 'Define areas, visual baseline, and timing margin',
                        body: 'Comparable photos and a clear date or event context prevent the procedure from being pressured against an unrealistic window.',
                    },
                    {
                        step: 'Immediate aftercare',
                        title: 'Respect swelling, sensitivity, and skin protection by technique',
                        body: 'The first days are usually for protecting the skin, avoiding unnecessary friction, and letting the early response settle.',
                    },
                    {
                        step: 'Useful review',
                        title: 'Repeat or combine only once the outcome can actually be read',
                        body: 'The right review avoids overtreatment. First interpret real evolution, then decide whether to repeat, wait, or combine.',
                    },
                ],
            },
            children: {
                eyebrow: 'Preparation and aftercare',
                title: `How to prepare ${serviceName} with a sustainable family-first route.`,
                description:
                    'In pediatric care the route improves when caregivers understand what to observe, what to apply at home, and when to return without improvising.',
                cards: [
                    {
                        step: 'Before the visit',
                        title: 'Bring simple photos, current routine, and symptom changes',
                        body: 'It helps to know what has already been used, whether the issue worsens in certain environments or schedules, and how easy home care has been.',
                    },
                    {
                        step: 'At-home aftercare',
                        title: 'The plan should be short, clear, and realistic for caregivers',
                        body: 'The best output is not the most complex one. It is the one caregivers can repeat consistently without creating new friction every day.',
                    },
                    {
                        step: 'Return earlier',
                        title: 'Escalate if there is pain, poor tolerance, or fast change',
                        body: 'When the case changes pace or new alerts appear, the correct route is early reassessment instead of repeating the same scheme.',
                    },
                ],
            },
        },
    },
};

const localeCopy = copy[locale] || copy.es;
const selected =
    variant === 'hub'
        ? localeCopy.hub
        : variant === 'telemedicine'
          ? localeCopy.telemedicine
        : localeCopy.service[category] || localeCopy.service.clinical;
---

<section
    class="sony-section sony-section--compact sony-protocol-rail"
    data-care-protocol
    data-care-protocol-variant={variant}
    data-care-protocol-category={variant === 'hub' ? 'mixed' : category}
>
    <div class="sony-section__head">
        <p>{selected.eyebrow}</p>
        <h2>{selected.title}</h2>
        <span>{selected.description}</span>
    </div>
    <div class="sony-protocol-rail__grid">
        {
            selected.cards.map((card) => (
                <article class="sony-protocol-rail__card" data-care-protocol-card>
                    <span>{card.step}</span>
                    <h3>{card.title}</h3>
                    <p>{card.body}</p>
                    {card.note && <strong>{card.note}</strong>}
                    {card.href && (
                        <a
                            class="sony-btn sony-btn--ghost"
                            href={card.href}
                            data-analytics-event="open_public_cta"
                            data-entry-surface={`prep_aftercare_${variant}`}
                            data-cta-target="service_hub"
                            data-service-category={card.category || 'all'}
                            data-service-intent={card.intent || 'all'}
                            data-catalog-category={card.category || 'all'}
                            data-catalog-intent={card.intent || 'all'}
                        >
                            {card.cta}
                        </a>
                    )}
                </article>
            ))
        }
    </div>
</section>
