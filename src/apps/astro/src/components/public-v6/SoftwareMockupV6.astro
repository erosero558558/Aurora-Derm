---
const { mockup = {}, compact = false } = Astro.props;

const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const normalizeText = (value) => (hasText(value) ? value.trim() : '');
const kind = ['phone', 'status', 'dashboard'].includes(mockup?.kind)
    ? mockup.kind
    : 'status';
const eyebrow = normalizeText(mockup?.eyebrow);
const title = normalizeText(mockup?.title);
const chips = Array.isArray(mockup?.chips)
    ? mockup.chips.map(normalizeText).filter(Boolean)
    : [];
const rows = Array.isArray(mockup?.rows)
    ? mockup.rows
          .map((row) => {
              const label = normalizeText(row?.label);
              const value = normalizeText(row?.value);
              if (!label || !value) {
                  return null;
              }
              return {
                  label,
                  value,
                  meta: normalizeText(row?.meta),
              };
          })
          .filter(Boolean)
    : [];
const footer = normalizeText(mockup?.footer);
const hasHeader = Boolean(eyebrow || title);
const summaryRows = kind === 'dashboard' ? rows.slice(0, 3) : [];
const bodyRows = kind === 'dashboard' ? rows.slice(3) : rows;
const statusLabel = chips[0] || eyebrow || title;
const statusMeta = chips.slice(1).join(' · ');
---

<article
    class:list={['v6-suite-mockup', `is-${kind}`, compact && 'is-compact']}
    data-v6-suite-mockup
    data-v6-suite-mockup-kind={kind}
>
    <div class="v6-suite-mockup__chrome" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
    </div>
    <div class="v6-suite-mockup__screen">
        {
            kind === 'phone' ? (
                <div class="v6-suite-mockup__device-top" aria-hidden="true">
                    <span></span>
                    <span></span>
                </div>
            ) : null
        }
        {
            kind === 'status' && statusLabel ? (
                <div class="v6-suite-mockup__statebar">
                    <strong>{statusLabel}</strong>
                    {statusMeta ? <p>{statusMeta}</p> : null}
                </div>
            ) : null
        }
        {
            kind === 'dashboard' && summaryRows.length ? (
                <div class="v6-suite-mockup__summary">
                    {summaryRows.map((row) => (
                        <article>
                            <p>{row.label}</p>
                            <strong>{row.value}</strong>
                            {row.meta ? <span>{row.meta}</span> : null}
                        </article>
                    ))}
                </div>
            ) : null
        }
        {
            hasHeader || chips.length ? (
                <header class="v6-suite-mockup__head">
                    <div>
                        {eyebrow ? <p>{eyebrow}</p> : null}
                        {title ? <h3>{title}</h3> : null}
                    </div>
                    {
                        chips.length ? (
                            <ul class="v6-suite-mockup__chips" aria-label={title || undefined}>
                                {chips.map((chip) => <li>{chip}</li>)}
                            </ul>
                        ) : null
                    }
                </header>
            ) : null
        }

        <div class:list={['v6-suite-mockup__body', kind === 'dashboard' && 'is-dashboard-body']}>
            {bodyRows.map((row, index) => (
                <article class:list={['v6-suite-mockup__row', index === 0 && 'is-primary']}>
                    <div class="v6-suite-mockup__row-head">
                        <p>{row.label}</p>
                        {row.meta ? <span>{row.meta}</span> : null}
                    </div>
                    <strong>{row.value}</strong>
                </article>
            ))}
        </div>

        {footer ? <footer class="v6-suite-mockup__footer">{footer}</footer> : null}
        {
            kind === 'phone' ? (
                <div class="v6-suite-mockup__device-bottom" aria-hidden="true"></div>
            ) : null
        }
    </div>
</article>
