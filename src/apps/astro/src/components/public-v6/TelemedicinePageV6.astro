---
import BookingStatusV6 from './BookingStatusV6.astro';
import InternalStatementBandV6 from './InternalStatementBandV6.astro';
import PageHeadV6 from './PageHeadV6.astro';

const { page = {}, locale = 'es', navModel = {} } = Astro.props;
const pageHeadUi = navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object' ? navModel.ui.pageHead : {};
const ui = page?.ui && typeof page.ui === 'object' ? page.ui : {};
const menuUi = ui?.menu && typeof ui.menu === 'object' ? ui.menu : {};
const thesisUi = ui?.thesis && typeof ui.thesis === 'object' ? ui.thesis : {};
const statementUi = ui?.statement && typeof ui.statement === 'object' ? ui.statement : {};
const internalMessageUi = ui?.internalMessage && typeof ui.internalMessage === 'object' ? ui.internalMessage : {};
const railUi = ui?.rail && typeof ui.rail === 'object' ? ui.rail : {};
const kpiUi = ui?.kpis && typeof ui.kpis === 'object' ? ui.kpis : {};
const initiativesUi = ui?.initiatives && typeof ui.initiatives === 'object' ? ui.initiatives : {};

const switchLabel = navModel?.header?.switchLabel || '';
const switchHref = navModel?.header?.switchHref || '#';
const menuLabel = navModel?.header?.menuLabel || '';
const breadcrumb = Array.isArray(page.breadcrumb) ? page.breadcrumb : [];
const blocks = Array.isArray(page.blocks) ? page.blocks : [];
const initiativesRaw = Array.isArray(page.initiatives) ? page.initiatives : [];
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const makeMenuItem = (label, href) => (hasText(label) ? { label: label.trim(), href } : null);
const blockModels = blocks.map((block, index) => {
    const items = Array.isArray(block.items) ? block.items : [];
    return {
        ...block,
        items,
        mediaSrc: block.image || '',
        anchorId: `v6-tele-block-${index + 1}`,
    };
});
const totalCriteria = blockModels.reduce((total, block) => total + block.items.length, 0);
const initiatives = initiativesRaw
    .map((item) => ({
        title: item.title || '',
        copy: item.copy || '',
        image: item.image || '',
        href: item.href || '',
    }))
    .filter((item) => hasText(item.title) && hasText(item.copy) && hasText(item.image) && hasText(item.href));

const pageMenuItems = blockModels
    .map((block) => makeMenuItem(block.title || '', `#${block.anchorId}`))
    .filter(Boolean);
if (initiatives.length) {
    const initiativesItem = makeMenuItem(menuUi.initiatives || '', '#v6-tele-initiatives');
    if (initiativesItem) {
        pageMenuItems.unshift(initiativesItem);
    }
}
const bookingItem = makeMenuItem(menuUi.bookingStatus || '', '#v6-booking-status');
if (bookingItem) {
    pageMenuItems.push(bookingItem);
}
const thesisEyebrow = thesisUi.eyebrow || '';
const thesisTitle = thesisUi.title || '';
const thesisBody = thesisUi.body || '';
const statement = {
    eyebrow: statementUi.eyebrow || '',
    title: statementUi.title || '',
    body: page.lead || '',
    signature: statementUi.signature || '',
    image: statementUi.image || '',
    alt: statementUi.alt || '',
};
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={pageMenuItems}
    copy={pageHeadUi}
/>

<section class="v6-page-hero-media is-internal" data-v6-internal-hero>
    <img src={page?.heroImage?.src} srcset={page?.heroImage?.srcset || undefined} alt={page?.heroImage?.alt || page.heading} sizes="100vw" loading="eager" fetchpriority="high" />
</section>

<section class="v6-internal-message" data-v6-internal-message>
    <h2>{page.lead}</h2>
    {internalMessageUi.description ? <p>{internalMessageUi.description}</p> : null}
</section>

<InternalStatementBandV6 statement={statement} variant="tele" />

<section class="v6-internal-thesis" data-v6-internal-thesis>
    <p>{thesisEyebrow}</p>
    <h2>{thesisTitle}</h2>
    <p>{thesisBody}</p>
</section>

<div class="v6-internal-shell" data-v6-internal-shell>
    <aside class="v6-internal-rail" data-v6-internal-rail>
        {railUi.title ? <p>{railUi.title}</p> : null}
        <nav data-v6-section-nav="internal" aria-label={railUi.aria || ''}>
            {
                pageMenuItems.map((item) => (
                    <a data-v6-section-link href={item.href}>{item.label}</a>
                ))
            }
        </nav>
    </aside>

    <div class="v6-internal-shell__body">
        <section class="v6-tele-kpis v6-tele-kpis--shell" aria-label={kpiUi.aria || ''}>
            <article>
                <p>{kpiUi.blocks || ''}</p>
                <h3>{String(blockModels.length).padStart(2, '0')}</h3>
            </article>
            <article>
                <p>{kpiUi.criteria || ''}</p>
                <h3>{String(totalCriteria).padStart(2, '0')}</h3>
            </article>
            <article>
                <p>{kpiUi.model || ''}</p>
                <h3>{kpiUi.modelValue || ''}</h3>
            </article>
        </section>

        {
            initiatives.length ? (
                <section id="v6-tele-initiatives" class="v6-tele-initiatives v6-tele-initiatives--shell" aria-label={initiativesUi.aria || ''}>
                    {
                    initiatives.map((item) => (
                        <a href={item.href} data-v6-tele-initiative>
                            <figure>
                                <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
                            </figure>
                            <div>
                                <h3>{item.title}</h3>
                                <p>{item.copy}</p>
                                {initiativesUi.ctaLabel ? (
                                    <strong>
                                        {initiativesUi.ctaLabel}
                                        <span aria-hidden="true">></span>
                                    </strong>
                                ) : null}
                            </div>
                        </a>
                        ))
                    }
                </section>
            ) : null
        }

        <section class="v6-tele-grid v6-tele-grid--shell">
            {
                blockModels.map((block, index) => (
                    <article id={block.anchorId} class:list={[index === 0 && 'is-lead']} data-v6-tele-block>
                        <figure class="v6-tele-grid__media">
                            <img src={block.mediaSrc} alt={block.title} loading="lazy" decoding="async" />
                        </figure>
                        <div class="v6-tele-grid__body">
                            <p class="v6-tele-grid__index">{String(index + 1).padStart(2, '0')}</p>
                            <h3>{block.title}</h3>
                            <ul>
                                {block.items.map((item) => <li>{item}</li>)}
                            </ul>
                            {ui.blockCtaLabel ? (
                                <a href="#v6-booking-status">
                                    {ui.blockCtaLabel}
                                    <span aria-hidden="true">></span>
                                </a>
                            ) : null}
                        </div>
                    </article>
                ))
            }
        </section>
    </div>
</div>

<BookingStatusV6 status={page.bookingStatus} sectionId="v6-booking-status" />
