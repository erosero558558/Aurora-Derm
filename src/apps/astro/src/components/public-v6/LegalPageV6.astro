---
import PageHeadV6 from './PageHeadV6.astro';
import InternalStatementBandV6 from './InternalStatementBandV6.astro';

const {
    page = {},
    indexItems = [],
    legalPages = {},
    currentSlug = '',
    locale = 'es',
    navModel = {},
} = Astro.props;

const switchLabel = navModel?.header?.switchLabel || (locale === 'en' ? 'ES' : 'EN');
const switchHref = navModel?.header?.switchHref || (locale === 'en' ? '/es/' : '/en/');
const menuLabel = navModel?.header?.menuLabel || 'Menu';
const sections = Array.isArray(page.sections) ? page.sections : [];
const safeLegalPages = legalPages && typeof legalPages === 'object' ? legalPages : {};
const sectionHighlights = sections.slice(0, 3).map((section) => ({
    title: section.title,
    count: Array.isArray(section.items) ? section.items.length : 0,
}));
const indexCards = indexItems.map((item, index) => {
    const source = safeLegalPages[item.slug] && typeof safeLegalPages[item.slug] === 'object'
        ? safeLegalPages[item.slug]
        : {};
    const sourceSections = Array.isArray(source.sections) ? source.sections : [];
    const clauses = sourceSections.reduce((total, section) => {
        const rows = Array.isArray(section.items) ? section.items.length : 0;
        return total + rows;
    }, 0);

    return {
        slug: item.slug,
        title: item.title,
        href: item.href,
        summary: source.summary || '',
        image: source.heroImage || page.heroImage,
        sectionLabel:
            locale === 'en'
                ? `Policy ${String(index + 1).padStart(2, '0')}`
                : `Politica ${String(index + 1).padStart(2, '0')}`,
        clauses,
    };
});
const sectionModels = sections.map((section, index) => ({
    ...section,
    items: Array.isArray(section.items) ? section.items : [],
    anchorId: `v6-legal-section-${index + 1}`,
}));
const pageMenuItems = [
    {
        label: locale === 'en' ? 'Legal index' : 'Indice legal',
        href: '#v6-legal-tabs',
    },
];

if (sectionHighlights.length) {
    pageMenuItems.push({
        label: locale === 'en' ? 'Clauses summary' : 'Resumen de clausulas',
        href: '#v6-legal-summary',
    });
}

if (indexCards.length) {
    pageMenuItems.push({
        label: locale === 'en' ? 'Policy index' : 'Indice de politicas',
        href: '#v6-legal-index-grid',
    });
}

sectionModels.forEach((section) => {
    if (section.title) {
        pageMenuItems.push({
            label: section.title,
            href: `#${section.anchorId}`,
        });
    }
});

const breadcrumb = [
    { label: locale === 'en' ? 'Home' : 'Inicio', href: locale === 'en' ? '/en/' : '/es/' },
    { label: 'Legal', href: locale === 'en' ? '/en/legal/terms/' : '/es/legal/terminos/' },
];
const thesisEyebrow = locale === 'en' ? 'Legal architecture' : 'Arquitectura legal';
const thesisTitle =
    locale === 'en'
        ? 'Clear clauses, explicit duties, and predictable patient decisions'
        : 'Clausulas claras, deberes explicitos y decisiones predecibles para el paciente';
const thesisBody =
    locale === 'en'
        ? 'Each policy is structured to reduce ambiguity in consent, privacy, and operational expectations across digital and in-clinic journeys.'
        : 'Cada politica esta estructurada para reducir ambiguedad en consentimiento, privacidad y expectativas operativas en recorridos digitales y presenciales.';
const statement = {
    eyebrow: locale === 'en' ? 'Legal direction' : 'Direccion legal',
    title:
        locale === 'en'
            ? 'Legal language should guide action, not add friction'
            : 'El lenguaje legal debe guiar accion, no sumar friccion',
    body:
        page.summary ||
        (locale === 'en'
            ? 'The legal framework clarifies responsibilities, patient rights, and operational limits for every route.'
            : 'El marco legal aclara responsabilidades, derechos del paciente y limites operativos para cada ruta.'),
    signature:
        locale === 'en'
            ? 'Policy and compliance office'
            : 'Oficina de politica y cumplimiento',
    image: '/images/optimized/team-rosero.webp',
    alt:
        locale === 'en'
            ? 'Legal and compliance direction portrait'
            : 'Retrato de direccion legal y cumplimiento',
};
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={page.heading}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={pageMenuItems}
/>

<section class="v6-page-hero-media is-internal" data-v6-internal-hero>
    <img src={page.heroImage} alt={page.heading} loading="eager" fetchpriority="high" />
</section>

<nav id="v6-legal-tabs" class="v6-legal-tabs" aria-label={locale === 'en' ? 'Legal index' : 'Indice legal'}>
    {
        indexItems.map((item) => (
            <a class:list={[item.slug === currentSlug && 'is-active']} href={item.href}>{item.title}</a>
        ))
    }
</nav>

<section class="v6-internal-message" data-v6-internal-message>
    <h2>{page.summary}</h2>
    <p>
        {
            locale === 'en'
                ? 'Operational policies are written for clarity, consent traceability, and responsible patient decisions.'
                : 'Las politicas operativas estan redactadas para claridad, trazabilidad de consentimiento y decisiones responsables del paciente.'
        }
    </p>
</section>

<InternalStatementBandV6 locale={locale} statement={statement} variant="legal" />

<section class="v6-internal-thesis" data-v6-internal-thesis>
    <p>{thesisEyebrow}</p>
    <h2>{thesisTitle}</h2>
    <p>{thesisBody}</p>
</section>

{
    indexCards.length ? (
        <section id="v6-legal-index-grid" class="v6-legal-index-grid" data-v6-legal-index>
            {
                indexCards.map((item) => (
                    <a class:list={[item.slug === currentSlug && 'is-active']} href={item.href}>
                        <figure>
                            <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
                        </figure>
                        <div>
                            <p>{item.sectionLabel}</p>
                            <h3>{item.title}</h3>
                            <p>{item.summary}</p>
                            <strong>
                                {locale === 'en' ? `${item.clauses} clauses` : `${item.clauses} clausulas`}
                            </strong>
                        </div>
                    </a>
                ))
            }
        </section>
    ) : null
}

{
    sectionHighlights.length ? (
        <section id="v6-legal-summary" class="v6-legal-summary">
            {
                sectionHighlights.map((item, index) => (
                    <article>
                        <p>{locale === 'en' ? 'Section' : 'Seccion'}</p>
                        <h3>{item.title}</h3>
                        <small>{locale === 'en' ? `Block ${String(index + 1).padStart(2, '0')}` : `Bloque ${String(index + 1).padStart(2, '0')}`}</small>
                        <strong>{locale === 'en' ? `${item.count} clauses` : `${item.count} clausulas`}</strong>
                    </article>
                ))
            }
        </section>
    ) : null
}

<section class="v6-legal-sections">
    {
        sectionModels.map((section, sectionIndex) => (
            <article id={section.anchorId} data-v6-legal-block>
                <header>
                    <p>{locale === 'en' ? `Section ${String(sectionIndex + 1).padStart(2, '0')}` : `Seccion ${String(sectionIndex + 1).padStart(2, '0')}`}</p>
                    <h3>{section.title}</h3>
                    <strong>{locale === 'en' ? `${section.items.length} clauses` : `${section.items.length} clausulas`}</strong>
                </header>
                <ol>
                    {section.items.map((item, itemIndex) => (
                        <li>
                            <span>{String(itemIndex + 1).padStart(2, '0')}</span>
                            <p>{item}</p>
                        </li>
                    ))}
                </ol>
            </article>
        ))
    }
</section>
