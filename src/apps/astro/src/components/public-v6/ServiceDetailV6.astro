---
import BookingStatusV6 from './BookingStatusV6.astro';
import InternalStatementBandV6 from './InternalStatementBandV6.astro';
import PageHeadV6 from './PageHeadV6.astro';

const {
    service = {},
    locale = 'es',
    navModel = {},
    servicePath = '#',
    hubPath = '#',
    related = [],
    ui = {},
} = Astro.props;

const pageHeadUi = navModel?.ui?.pageHead && typeof navModel.ui.pageHead === 'object' ? navModel.ui.pageHead : {};
const menuUi = ui?.menu && typeof ui.menu === 'object' ? ui.menu : {};
const breadcrumbUi = ui?.breadcrumb && typeof ui.breadcrumb === 'object' ? ui.breadcrumb : {};
const thesisUi = ui?.thesis && typeof ui.thesis === 'object' ? ui.thesis : {};
const statementUi = ui?.statement && typeof ui.statement === 'object' ? ui.statement : {};
const railUi = ui?.rail && typeof ui.rail === 'object' ? ui.rail : {};
const glanceUi = ui?.glance && typeof ui.glance === 'object' ? ui.glance : {};
const sectionsUi = ui?.sections && typeof ui.sections === 'object' ? ui.sections : {};
const bookingStatusUi =
    ui?.bookingStatus && typeof ui.bookingStatus === 'object'
        ? ui.bookingStatus
        : {};

const switchLabel = navModel?.header?.switchLabel || '';
const switchHref = navModel?.header?.switchHref || '#';
const menuLabel = navModel?.header?.menuLabel || '';
const checkpoints = Array.isArray(service.bullets) ? service.bullets : [];
const processSteps = Array.isArray(service.process) ? service.process : [];
const faqItems = Array.isArray(service.faq) ? service.faq : [];
const faqAnswers = Array.isArray(service.faqAnswers) ? service.faqAnswers : [];
const hasText = (value) => typeof value === 'string' && value.trim().length > 0;
const makeMenuItem = (label, href) => (hasText(label) ? { label: label.trim(), href } : null);
const faqModels = faqItems
    .map((question, index) => ({
        question,
        answer: faqAnswers[index],
    }))
    .filter((item) => hasText(item.question) && hasText(item.answer));
const sectionMenuItems = [
    makeMenuItem(menuUi.glance || '', '#v6-service-glance'),
    makeMenuItem(menuUi.checkpoints || '', '#v6-service-checkpoints'),
    makeMenuItem(menuUi.process || '', '#v6-service-process'),
    makeMenuItem(menuUi.faq || '', '#v6-service-faq'),
].filter(Boolean);

if (related.length) {
    const relatedItem = makeMenuItem(menuUi.related || '', '#v6-service-related');
    if (relatedItem) {
        sectionMenuItems.push(relatedItem);
    }
}

const bookingMenuItem = makeMenuItem(menuUi.booking || '', '#v6-booking-status');
if (bookingMenuItem) {
    sectionMenuItems.push(bookingMenuItem);
}

const breadcrumb = [
    { label: breadcrumbUi.home || '', href: locale === 'en' ? '/en/' : '/es/' },
    { label: breadcrumbUi.hub || '', href: hubPath },
    { label: service.title || '', href: servicePath },
];
const thesisEyebrow = thesisUi.eyebrow || '';
const thesisTitle = `${service.title || ''} ${thesisUi.titleSuffix || ''}`.trim();
const thesisBody = thesisUi.body || '';
const statementTitleTemplate = statementUi.titleTemplate || '{service}';
const statement = {
    eyebrow: statementUi.eyebrow || '',
    title: statementTitleTemplate.replace('{service}', service.title || ''),
    body: service.lead,
    signature: statementUi.signature || '',
    image: statementUi.image || '',
    alt: statementUi.alt || '',
};
const relatedCta = ui.relatedCta || '';
const faqPrefix = ui.faqPrefix || '';
---

<PageHeadV6
    breadcrumb={breadcrumb}
    heading={service.title}
    locale={locale}
    switchLabel={switchLabel}
    switchHref={switchHref}
    menuLabel={menuLabel}
    menuItems={sectionMenuItems}
    copy={pageHeadUi}
/>

<section class="v6-page-hero-media is-internal" data-v6-internal-hero>
    <img src={service.heroImage} alt={service.heroAlt || service.title} loading="eager" fetchpriority="high" />
</section>

<section class="v6-internal-message" data-v6-internal-message>
    <h2>{service.summary}</h2>
    {service.lead ? <p>{service.lead}</p> : null}
</section>

<InternalStatementBandV6 statement={statement} variant="service" />

<section class="v6-internal-thesis" data-v6-internal-thesis>
    <p>{thesisEyebrow}</p>
    <h2>{thesisTitle}</h2>
    <p>{thesisBody}</p>
</section>

<div class="v6-internal-shell" data-v6-internal-shell>
    <aside class="v6-internal-rail" data-v6-internal-rail>
        {railUi.title ? <p>{railUi.title}</p> : null}
        <nav data-v6-section-nav="internal" aria-label={railUi.aria || ''}>
            {
                sectionMenuItems.map((item) => (
                    <a data-v6-section-link href={item.href}>{item.label}</a>
                ))
            }
        </nav>
    </aside>

    <div class="v6-internal-shell__body">
        <section id="v6-service-glance" class="v6-service-glance v6-service-glance--shell">
            <article>
                <p>{glanceUi.routeType || ''}</p>
                <h3>{service.category || ''}</h3>
            </article>
            <article>
                <p>{glanceUi.checkpoints || ''}</p>
                <h3>{checkpoints.length}</h3>
            </article>
            <article>
                <p>{glanceUi.processStages || ''}</p>
                <h3>{processSteps.length}</h3>
            </article>
        </section>

        <section class="v6-service-detail v6-service-detail--shell">
            <article id="v6-service-checkpoints" class="v6-service-detail__column">
                <h3>{sectionsUi.checkpointsTitle || ''}</h3>
                <ul class="v6-service-checklist">
                    {
                        checkpoints.map((item) => (
                            <li>
                                <span class="v6-service-checklist__dot" aria-hidden="true"></span>
                                <p>{item}</p>
                            </li>
                        ))
                    }
                </ul>
            </article>

            <article id="v6-service-process" class="v6-service-detail__column">
                <h3>{sectionsUi.processTitle || ''}</h3>
                <ol class="v6-service-process">
                    {
                        processSteps.map((item, index) => (
                            <li>
                                <span>{String(index + 1).padStart(2, '0')}</span>
                                <p>{item}</p>
                            </li>
                        ))
                    }
                </ol>
            </article>

            <article id="v6-service-faq" class="v6-service-detail__column v6-service-detail__full">
                <h3>{sectionsUi.faqTitle || ''}</h3>
                <div class="v6-service-faq-grid">
                    {
                        faqModels.map((item, index) => (
                            <article>
                                <p>{`${faqPrefix}${index + 1}`}</p>
                                <h4>{item.question}</h4>
                                <small>{item.answer}</small>
                            </article>
                        ))
                    }
                </div>
            </article>
        </section>

        {
            related.length ? (
                <section id="v6-service-related" class="v6-related-grid v6-related-grid--shell">
                    <h2>{sectionsUi.relatedTitle || ''}</h2>
                    <div>
                        {
                            related.map((item) => (
                                <a href={item.href}>
                                    <img src={item.heroImage} alt={item.title} loading="lazy" decoding="async" />
                                    {item.category ? <p>{item.category}</p> : null}
                                    <h3>{item.title}</h3>
                                    {item.summary ? <p>{item.summary}</p> : null}
                                    {relatedCta ? <strong>{relatedCta}</strong> : null}
                                </a>
                            ))
                        }
                    </div>
                </section>
            ) : null
        }
    </div>
</div>

<BookingStatusV6
    status={{
        eyebrow: bookingStatusUi.eyebrow || '',
        title: bookingStatusUi.title || '',
        description: bookingStatusUi.description || '',
        ctaLabel: bookingStatusUi.ctaLabel || '',
        ctaHref: bookingStatusUi.ctaHref || '#',
    }}
    sectionId="v6-booking-status"
/>
