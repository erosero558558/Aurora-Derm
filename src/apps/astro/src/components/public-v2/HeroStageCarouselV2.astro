---
const { slides = [], locale = 'es' } = Astro.props;
---

<section class="hero-stage" data-stage-carousel>
    <div class="hero-stage__viewport">
        {
            slides.map((slide, index) => (
                <article class:list={['hero-stage__slide', index === 0 && 'is-active']} data-stage-slide>
                    <img src={slide.media} alt={slide.title} loading={index === 0 ? 'eager' : 'lazy'} />
                    <div class="hero-stage__overlay">
                        <p class="hero-stage__category">{slide.category}</p>
                        <h1>{slide.title}</h1>
                        <p>{slide.deck}</p>
                        <div class="hero-stage__actions">
                            <a href={slide.primary.href} class="hero-stage__cta hero-stage__cta--primary" data-analytics-event="open_public_cta" data-entry-surface={`stage_${slide.id}_primary`} data-cta-target={slide.primary.target}>{slide.primary.label}</a>
                            <a href={slide.secondary.href} class="hero-stage__cta hero-stage__cta--secondary" data-analytics-event="open_public_cta" data-entry-surface={`stage_${slide.id}_secondary`} data-cta-target={slide.secondary.target}>{slide.secondary.label}</a>
                        </div>
                    </div>
                </article>
            ))
        }
    </div>
    <div class="hero-stage__rail" aria-label={locale === 'en' ? 'Featured stories' : 'Historias destacadas'}>
        {
            slides.map((slide, index) => (
                <button type="button" class:list={['hero-stage__dot', index === 0 && 'is-active']} data-stage-trigger data-index={index}>
                    <span>{slide.category}</span>
                    <strong>{slide.title}</strong>
                </button>
            ))
        }
    </div>
</section>
