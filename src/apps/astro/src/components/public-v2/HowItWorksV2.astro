---
const { eyebrow = '', points = [], locale = 'es' } = Astro.props;
---

<section class="service-story-v2" data-how-it-works>
    <div><p>{eyebrow}</p><h2>{locale === 'en' ? 'How the remote route is structured.' : 'Como se estructura la ruta remota.'}</h2></div>
    <div class="service-story-v2__grid">
        {points.map((point) => <article><p>{point}</p></article>)}
    </div>
</section>
