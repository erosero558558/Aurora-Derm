---
const { hero } = Astro.props;
---

<section class="hub-hero-v2" data-telemedicine-hero>
    <div class="hub-hero-v2__copy">
        <p>{hero.eyebrow}</p>
        <h1>{hero.title}</h1>
        <p>{hero.deck}</p>
    </div>
    <div class="hub-hero-v2__media"><img src={hero.media} alt={hero.title} loading="eager" /></div>
</section>
