---
const { page } = Astro.props;
---

<section class="legal-article-v2" data-legal-article>
    <div class="legal-article-v2__highlights">
        {
            page.highlights.map((item) => (
                <article>
                    <p>{item.eyebrow}</p>
                    <h2>{item.title}</h2>
                    <p>{item.body}</p>
                </article>
            ))
        }
    </div>
    <div class="legal-article-v2__sections">
        {
            page.sections.map((section) => (
                <article>
                    <h3>{section.title}</h3>
                    <p>{section.body}</p>
                    <ul>{section.items.map((item) => <li>{item}</li>)}</ul>
                </article>
            ))
        }
    </div>
</section>
