---
const { eyebrow = '', points = [], locale = 'es' } = Astro.props;
---

<section class="service-timeline-v2" data-escalation-model>
    <p>{eyebrow || (locale === 'en' ? 'Escalation model' : 'Modelo de escalamiento')}</p>
    <div class="service-timeline-v2__steps">
        {points.map((point, index) => <article><span>{`0${index + 1}`}</span><h3>{point}</h3></article>)}
    </div>
</section>
