---
import BookingShellV2 from './BookingShellV2.astro';

const { eyebrow = '', title = '', deck = '', actionLabel = '', serviceHint = 'consulta', locale = 'es' } = Astro.props;
---

<section class="booking-bridge" data-booking-bridge-band>
    <div class="booking-bridge__intro">
        <p>{eyebrow}</p>
        <h2>{title}</h2>
        <p>{deck}</p>
        <a href="#citas" class="hero-stage__cta hero-stage__cta--primary" data-analytics-event="open_public_cta" data-entry-surface="booking_bridge_primary" data-cta-target="booking">
            {actionLabel}
        </a>
    </div>
    <section id="citas" class="booking-bridge__mount" data-service-hint={serviceHint}>
        <BookingShellV2 locale={locale} />
    </section>
</section>
