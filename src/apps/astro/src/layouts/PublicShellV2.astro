---
import '../styles/public-v2.css';
import '../styles/public-v2-motion.css';
import PublicNavBarV2 from '../components/public-v2/PublicNavBarV2.astro';
import PublicFooterV2 from '../components/public-v2/PublicFooterV2.astro';
import LegacyRuntimeBridgeV2 from '../components/public-v2/LegacyRuntimeBridgeV2.astro';

const {
    title = 'Piel en Armonia',
    description = '',
    locale = 'es',
    canonicalPath = '/es/',
    alternatePath = '/en/',
    pathname = '/es/',
    navModel,
} = Astro.props;

const origin = 'https://pielarmonia.com';
const canonical = new URL(canonicalPath, origin).toString();
const alternate = new URL(alternatePath, origin).toString();
const xDefault = locale === 'en' ? alternate : canonical;
---

<!doctype html>
<html lang={locale}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="robots" content="index,follow,max-image-preview:large" />
        <link rel="canonical" href={canonical} />
        <link rel="alternate" href={alternate} hreflang={locale === 'es' ? 'en' : 'es'} />
        <link rel="alternate" href={canonical} hreflang={locale} />
        <link rel="alternate" href={xDefault} hreflang="x-default" />
        <meta property="og:type" content="website" />
        <meta property="og:site_name" content="Piel en Armonia" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonical} />
        <meta property="og:image" content="https://pielarmonia.com/images/optimized/showcase-hero.jpg" />
        <meta name="theme-color" content="#f3f4f1" />
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <link rel="manifest" href="/manifest.json" />
        <script src="/js/public-v2-shell.js?v=public-v2-shell-20260228-v1" defer></script>
        <script src="/js/service-navigation-analytics.js?v=service-analytics-20260228-v3" defer></script>
    </head>
    <body data-public-shell>
        <a class="public-skip-link" href="#main-content">{locale === 'en' ? 'Skip to content' : 'Saltar al contenido'}</a>
        <PublicNavBarV2 navModel={navModel} />
        <main id="main-content">
            <slot />
        </main>
        <PublicFooterV2 locale={locale} />
        <LegacyRuntimeBridgeV2 locale={locale} />
    </body>
</html>
