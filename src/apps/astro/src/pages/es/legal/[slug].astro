---
import PublicShellV2 from '../../../layouts/PublicShellV2.astro';
import LegalHeroV2 from '../../../components/public-v2/LegalHeroV2.astro';
import LegalPolicyTabsV2 from '../../../components/public-v2/LegalPolicyTabsV2.astro';
import LegalArticleLayoutV2 from '../../../components/public-v2/LegalArticleLayoutV2.astro';
import SupportBandV2 from '../../../components/public-v2/SupportBandV2.astro';
import BookingBridgeBandV2 from '../../../components/public-v2/BookingBridgeBandV2.astro';
import { getLegalIndex, getLegalPageV2Data, getPublicNavigationModel } from '../../../lib/public-v2.js';

export async function getStaticPaths() {
    return ['terminos', 'privacidad', 'cookies', 'aviso-medico'].map((slug) => ({ params: { slug } }));
}

const locale = 'es';
const { slug } = Astro.params;
const page = getLegalPageV2Data(slug, locale);
if (!page) throw new Error(`Pagina legal no encontrada: ${slug}`);
const pathname = `/es/legal/${slug}/`;
const navModel = getPublicNavigationModel(locale, pathname);
const legalIndex = getLegalIndex(locale);
const altMap = { terminos: 'terms', privacidad: 'privacy', cookies: 'cookies', 'aviso-medico': 'medical-disclaimer' };
---

<PublicShellV2 title={`${page.title} | Piel en Armonia`} description={page.description} locale={locale} canonicalPath={pathname} alternatePath={`/en/legal/${altMap[slug]}/`} pathname={pathname} navModel={navModel}>
    <LegalHeroV2 page={page} />
    <LegalPolicyTabsV2 items={legalIndex} currentHref={pathname} />
    <LegalArticleLayoutV2 page={page} />
    <SupportBandV2 eyebrow={page.supportBand.eyebrow} title={page.supportBand.title} deck={page.supportBand.deck} locale={locale} />
    <BookingBridgeBandV2 eyebrow="Reserva" title="La capa legal no rompe la continuidad de reserva." deck="Puedes revisar politica y seguir con la misma entrada de booking si tu caso ya esta claro." actionLabel="Abrir reserva" serviceHint="consulta" locale={locale} />
</PublicShellV2>
