---
import PublicShellV5 from '../../layouts/PublicShellV5.astro';
import ResponsiveMediaImageV5 from '../../components/public-v5/ResponsiveMediaImageV5.astro';
import { getLocalizedBookingOptions } from '../../lib/content.js';
import { getHomeV5Data, getPublicNavigationModel } from '../../lib/public-v5.js';

const locale = 'es';
const pathname = '/es/';
const page = getHomeV5Data(locale);
const navModelBase = getPublicNavigationModel(locale, pathname);
const navModel = {
    ...navModelBase,
    bookingHref: '/es/servicios/#citas',
};

const hero = page.slides?.[0] || null;
const families = Array.isArray(page.families) ? page.families.slice(0, 3) : [];
const doctors = Array.isArray(page.doctors) ? page.doctors.slice(0, 2) : [];
const pricing = getLocalizedBookingOptions(locale).slice(0, 4);
const heroMediaMeta = hero?.mediaMeta || {};
const heroMediaSources = Array.isArray(heroMediaMeta?.sources)
    ? heroMediaMeta.sources
    : [];
const preferredHeroSource =
    heroMediaSources.find((source) => source?.type === 'image/webp') ||
    heroMediaSources.find((source) => source?.type === 'image/avif') ||
    null;
const preferredHeroSrcSet = String(preferredHeroSource?.srcset || '').trim();
const preloadImageSrc =
    (preferredHeroSrcSet.split(',')[0] || '').trim().split(/\s+/u)[0] ||
    heroMediaMeta?.src ||
    hero?.media ||
    '/images/optimized/showcase-hero.webp';
const preloadImageSrcSet = preferredHeroSrcSet || heroMediaMeta?.srcset || '';
const preloadImageSizes = '(max-width: 1120px) 85vw, 50vw';
const preloadImageType = String(preferredHeroSource?.type || 'image/webp').trim();
const heroMedia =
    hero?.mediaMeta && typeof hero.mediaMeta === 'object'
        ? {
              ...hero.mediaMeta,
              sources: heroMediaSources.filter(
                  (source) => source?.type !== 'image/avif'
              ),
          }
        : hero?.media;
---

<PublicShellV5
    title={page.title}
    description={page.description}
    locale={locale}
    canonicalPath="/es/"
    alternatePath="/en/"
    pathname={pathname}
    navModel={navModel}
    templateId="home_v5"
    enableRuntimeBridge={false}
    compactFooter={true}
    preloadImageSrc={preloadImageSrc}
    preloadImageSrcSet={preloadImageSrcSet}
    preloadImageSizes={preloadImageSizes}
    preloadImageType={preloadImageType}
>
    <section class="sony-home-hero" data-template-block="home_hero_v5">
        <div class="sony-home-hero__copy">
            <p>{hero?.eyebrow || 'Dermatologia de precision'}</p>
            <h1>{hero?.title || 'Dermatologia clinica con decisiones claras.'}</h1>
            <p>{hero?.deck || 'Diagnostico, evidencia y reserva con continuidad en una sola experiencia.'}</p>
            <ul class="sony-home-hero__chips">
                {(hero?.stats || []).slice(0, 3).map((item) => <li>{item}</li>)}
            </ul>
            <div class="sony-home-hero__actions">
                <a
                    href="/es/servicios/#citas"
                    class="hero-stage__cta hero-stage__cta--primary"
                    data-analytics-event="open_public_cta"
                    data-entry-surface="home_hero_primary"
                    data-cta-target="booking"
                >
                    Reservar valoracion
                </a>
                <a
                    href="/es/servicios/"
                    class="sony-quiet-link"
                    data-analytics-event="open_public_cta"
                    data-entry-surface="home_hero_secondary"
                    data-cta-target="service_hub"
                >
                    Ver servicios
                </a>
            </div>
        </div>
        <div class="sony-home-hero__media">
            <ResponsiveMediaImageV5
                media={heroMedia}
                fallbackSrc={hero?.media || '/images/optimized/showcase-hero.webp'}
                fallbackAlt={hero?.mediaMeta?.alt || 'Consulta dermatologica con enfoque diagnostico'}
                loading="eager"
                fetchpriority="high"
                sizes={preloadImageSizes}
            />
        </div>
    </section>

    <section class="sony-home-paths" data-template-block="home_paths_v5">
        <div class="sony-home-head">
            <p>Rutas clinicas</p>
            <h2>Elige la ruta correcta desde la primera lectura.</h2>
        </div>
        <div class="sony-home-paths__grid">
            {
                families.map((family) => (
                    <article class="sony-home-card">
                        <h3>{family.label}</h3>
                        <p>{family.deck}</p>
                        <a
                            href={family.href}
                            class="public-link-arrow"
                            data-analytics-event="open_public_cta"
                            data-entry-surface="home_clinical_paths"
                            data-cta-target="service_hub"
                            data-catalog-category={family.id}
                            data-catalog-intent="all"
                        >
                            Abrir ruta
                        </a>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="sony-home-authority" data-template-block="home_authority_v5">
        <div class="sony-home-head">
            <p>Autoridad medica</p>
            <h2>Direccion clinica visible y conectada con cada programa.</h2>
        </div>
        <div class="sony-home-authority__grid">
            {
                doctors.map((doctor) => (
                    <article class="sony-home-doctor">
                        <img
                            src={doctor?.mediaMeta?.src || doctor?.media || '/images/optimized/showcase-clinic.webp'}
                            alt={doctor?.name || 'Especialista dermatologico'}
                            loading="lazy"
                            decoding="async"
                        />
                        <div>
                            <p>{doctor.role}</p>
                            <h3>{doctor.name}</h3>
                            <p>{doctor.deck}</p>
                        </div>
                    </article>
                ))
            }
        </div>
    </section>

    <section class="sony-home-pricing" data-template-block="home_pricing_v5">
        <div class="sony-home-head">
            <p>Precio transparente</p>
            <h2>Precios publicos exactos antes de reservar.</h2>
        </div>
        <div class="sony-home-pricing__grid">
            {
                pricing.map((item) => (
                    <article class="sony-home-price">
                        <h3>{item.label}</h3>
                        <p>{item.priceLabelShort}</p>
                        <small>{item.priceDisclaimer}</small>
                    </article>
                ))
            }
        </div>
        <p class="sony-home-pricing__policy-note">
            Politica de cancelacion y reprogramacion disponible en la seccion legal.
        </p>
    </section>

    <section class="sony-home-booking" data-template-block="home_booking_v5">
        <div>
            <p>Reserva</p>
            <h2>Reserva inmediata con continuidad clinica.</h2>
            <p>La reserva completa y el pago seguro estan en la ruta de servicios para mantener una experiencia limpia.</p>
        </div>
        <div class="sony-home-booking__actions">
            <a
                href="/es/servicios/#citas"
                class="hero-stage__cta hero-stage__cta--primary"
                data-analytics-event="open_public_cta"
                data-entry-surface="home_booking_primary"
                data-cta-target="booking"
            >
                Abrir reserva
            </a>
            <a
                href="/es/telemedicina/"
                class="sony-quiet-link"
                data-analytics-event="open_public_cta"
                data-entry-surface="home_booking_secondary"
                data-cta-target="telemedicine"
            >
                Telemedicina
            </a>
        </div>
    </section>
</PublicShellV5>
