---
import PublicShellV5 from '../../../layouts/PublicShellV5.astro';
import ServiceHubV5 from '../../../components/public-v5/ServiceHubV5.astro';
import { getHubV5Data, getPublicNavigationModel } from '../../../lib/public-v5.js';

const locale = 'es';
const pathname = '/es/servicios/';
const page = getHubV5Data(locale);
const navModel = getPublicNavigationModel(locale, pathname);
const heroMediaMeta = page?.hero?.mediaMeta || {};
const preloadImageSrc = heroMediaMeta?.src || page?.hero?.media || '';
const preloadImageSrcSet = heroMediaMeta?.srcset || '';
const preloadImageSizes =
    heroMediaMeta?.sizes || '(max-width: 1024px) 100vw, 44vw';
---

<PublicShellV5
    title={page.title}
    description={page.description}
    locale={locale}
    canonicalPath={pathname}
    alternatePath="/en/services/"
    pathname={pathname}
    navModel={navModel}
    templateId="service_hub_v5"
    enableRuntimeBridge={false}
    compactFooter={true}
    preloadImageSrc={preloadImageSrc}
    preloadImageSrcSet={preloadImageSrcSet}
    preloadImageSizes={preloadImageSizes}
>
    <ServiceHubV5 page={page} locale={locale} />
</PublicShellV5>
